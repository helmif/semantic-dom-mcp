{
  "name": "semantic-dom-mcp",
  "version": "0.4.0",
  "description": "Local MCP server (stdio) that extracts a live page's DOM into compact Semantic JSON with Playwright-native locators, for consistent AI-generated Playwright tests.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "semantic-dom-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "author": "Helmi Fauzi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helmif/semantic-dom-mcp.git"
  },
  "homepage": "https://github.com/helmif/semantic-dom-mcp#readme",
  "bugs": "https://github.com/helmif/semantic-dom-mcp/issues",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "playwright",
    "qa",
    "test-automation",
    "dom-extraction",
    "locators",
    "e2e-testing",
    "ai-agents"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx ./src/index.ts",
    "start": "node ./dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bench": "tsx benchmark/run.mts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "playwright": "1.61.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
